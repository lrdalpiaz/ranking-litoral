extends layout

block content
  style.
    /* Garante que o texto dentro da busca do Tom Select seja visível */
    .ts-control {
      border-color: #1b4d3e !important;
      padding: 8px !important;
    }
    .ts-dropdown .active {
      background-color: #d35400 !important; /* Cor de Saibro ao selecionar */
      color: white !important;
    }
    .ts-control .item {
      background-color: #1b4d3e !important; /* Etiqueta do jogador em Verde */
      color: white !important;
      border-radius: 3px !important;
    }
  .container.mt-4
    h2.fw-bold.mb-4 🏆 Configurar Nova Temporada
    form(action="/tournaments/create" method="POST")
      .card.shadow-sm.mb-4
        .card-body
          .row
            .col-md-6.mb-3
              label.form-label Nome da Temporada
              input.form-control(name="name" placeholder="Ex: Open Verão 2024" required)
            .col-md-6.mb-3
              label.form-label Data de Início
              input.form-control(type="date" name="startDate" required)

      h4.mb-3 Classes e Grupos
      each cls in ['A', 'B', 'C', 'D', 'E']
        .card.mb-4.border-0.shadow-sm
          //- Forçamos o fundo verde e a cor do texto para branco total
          .card-header.d-flex.justify-content-between.align-items-center(style="background-color: #1b4d3e; border-bottom: 3px solid #d35400; padding: 12px 20px;")
            
            //- Aqui está a correção: usamos h5 com cor branca forçada
            h5.mb-0.fw-bold(style="color: #1b4d3e !important; text-shadow: 1px 1px 2px rgba(0,0,0,0.2);") CLASSE #{cls}
            
            div.d-flex.align-items-center
              label.me-2.small.fw-bold(style="color: #1b4d3e !important;") NÚMERO DE GRUPOS:
              input.form-control.form-control-sm.text-center(
                type="number" 
                name=`groupsCount_${cls}` 
                min="0" 
                max="8" 
                value="0" 
                style="width: 60px; font-weight: 900; color: #1b4d3e; border: 2px solid #d35400;" 
                onchange=`updateGroups('${cls}', this.value)`
              )
          
          .card-body
            .row(id=`groups-container-${cls}`)
              .col-12.text-muted.small Nenhum grupo definido para esta classe.

      button#btnGenerate.btn.btn-success.btn-lg.w-100.my-4(type="button" onclick="submitTournament()") 
        i.bi.bi-gear-fill.me-2
      
        | Gerar Torneio
      
      script.
        async function submitTournament() {
          const btn = document.getElementById('btnGenerate');
          const form = document.querySelector('form');
          const formData = new FormData(form);
          
          // Converte FormData para um objeto simples
          const data = {};
          formData.forEach((value, key) => {
            if (!data[key]) { data[key] = value; return; }
            if (!Array.isArray(data[key])) { data[key] = [data[key]]; }
            data[key].push(value);
          });
      
          btn.disabled = true;
          btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Processando...';
      
          try {
            const response = await fetch('/tournaments/create', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(data)
            });
      
            const result = await response.json();
      
            if (response.ok && result.success) {
              // Sucesso: Redireciona
              window.location.href = '/matches/pending';
            } else {
              // Erro: Mostra o Toast sem recarregar a página
              showToast(result.error || 'Erro ao processar dados do torneio.');
            }
          } catch (err) {
            showToast('Erro de conexão com o servidor.');
          } finally {
            btn.disabled = false;
            btn.innerHTML = '<i class="bi bi-gear-fill me-2"></i> Gerar Torneio';
          }
        }
      
        function showToast(message) {
          document.getElementById('errorMessage').innerText = message;
          const toastEl = document.getElementById('errorToast');
          const toast = new bootstrap.Toast(toastEl);
          toast.show();
        }

    script.
      // Passa a lista de jogadores do banco para o JavaScript
      const allPlayers = !{JSON.stringify(players)};

      function updateGroups(cls, count) {
        const container = document.getElementById(`groups-container-${cls}`);
        container.innerHTML = '';

        if (count == 0) {
          container.innerHTML = '<div class="col-12 text-muted small">Nenhum grupo definido.</div>';
          return;
        }

        for (let i = 1; i <= count; i++) {
          const groupDiv = document.createElement('div');
          groupDiv.className = 'col-md-6 mb-4';
          
          const selectId = `select-${cls}-${i}`;
          let options = allPlayers.map(p => `<option value="${p.email}">${p.name}</option>`).join('');
          
          groupDiv.innerHTML = `
            <label class="fw-bold small mb-1">Grupo ${i}</label>
            <select id="${selectId}" name="players_${cls}_${i}" multiple placeholder="Busque pelo nome...">
              ${options}
            </select>
          `;
          container.appendChild(groupDiv);

          // Inicializa a busca no campo recém criado
          new TomSelect(`#${selectId}`, {
            plugins: ['remove_button'],
            maxItems: 12,
            persist: false,
            create: false,
            allowEmptyOption: true,
            // ESTA É A MÁGICA:
            onItemAdd: function() {
              this.setTextboxValue(''); // Limpa o texto digitado
              this.refreshOptions();    // Reseta a lista de sugestões para o estado inicial
            }
          });
        }
      }
  //- Container para o Toast (Canto superior direito)
  .toast-container.position-fixed.top-0.end-0.p-3(style="z-index: 1055")
    #errorToast.toast.align-items-center.text-white.bg-danger.border-0(role="alert" aria-live="assertive" aria-atomic="true")
      .d-flex
        .toast-body
          i.bi.bi-exclamation-triangle.me-2
          span#errorMessage Erro ao gerar torneio.
        button.btn-close.btn-close-white.me-2.m-auto(type="button" data-bs-dismiss="toast")
