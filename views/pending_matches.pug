extends layout

block content
  .container.mt-4#main-container(data-class=selectedClass data-group=selectedGroup data-tournament=selectedTournament)
    .d-flex.justify-content-between.align-items-center.mb-4(data-aos="fade-down")
      h2.fw-bold.text-uppercase 📅 Agenda de jogos
      if selectedClass || selectedGroup
        a.btn.btn-sm.btn-outline-danger.rounded-0(href="/matches/pending") Limpar Filtros

    //- Filtros Persistentes
    .card.border-0.shadow-sm.mb-4(data-aos="fade-down")
      .card-body.bg-white.p-4
        .row.align-items-end.g-2
          //- Tournament
          .col-md-4
            label.small.text-uppercase.fw-bold.text-muted.mb-1 🏆 Temporada
            select.form-select.form-select-sm.border-success(
              style="height: 38px;" 
              onchange=`location.href='/matches/pending?tournamentId=' + this.value + '&class=${selectedClass}&group=${selectedGroup}'`
            )
              if tournaments && tournaments.length > 0
                each t in tournaments
                  option(value=t._id.toString() selected=(t._id.toString() === selectedTournament)) #{t.name}
              else
                option(disabled) No tournaments found
        
          //- Class
          .col-md-4
            label.small.text-uppercase.fw-bold.text-muted.mb-1 🎾 Classe
            .btn-group.w-100(style="height: 38px;")
              each c in ['A', 'B', 'C', 'D', 'E']
                button.btn.btn-sm.filter-btn-class(
                  type="button"
                  onclick=`filterMatches('${c}', null)` 
                  class=(selectedClass == c ? 'btn-success fw-bold' : 'btn-outline-success')
                  data-class=c
                )= c
          
          //- Filtro de Grupo
          .col-md-4
            label.small.text-uppercase.fw-bold.text-muted.mb-1 👥 Grupo
            .btn-group.w-100(style="height: 38px;")
              each g in [1, 2, 3, 4]
                button.btn.btn-sm.filter-btn-group(
                  type="button"
                  onclick=`filterMatches(null, '${g}')` 
                  class=(selectedGroup == g ? 'btn-dark fw-bold' : 'btn-outline-dark')
                  data-group=g
                )= g

    #matches-list-container
      if matches.length > 0
        - var currentRound = 0
        each match, index in matches
          if match.round !== currentRound
            - currentRound = match.round
            .mt-5.mb-3(data-aos="fade-right")
              h4.text-uppercase.fw-900(style="color: var(--clay-orange); border-left: 4px solid var(--clay-orange); padding-left: 15px;")
  
                | Semana #{currentRound} 
                small.text-muted.fs-6.ms-2 — Data limite: #{match.deadline.toLocaleDateString('pt-BR')}
          
          .card.mb-2.border-0.shadow-sm(data-aos="fade-up" data-aos-delay=(index % 5) * 50)
            .card-body.py-3(id=`match-row-${match._id}` class=match.played ? 'bg-light' : '')
              //- Dentro do card-body do loop de matches
              .row.align-items-center
                //- Status (Aumente para col-md-1 se necessário)
                .col-md-2.text-center.border-end
                  span.badge.rounded-pill(id=`status-${match._id}` class=match.played ? 'bg-secondary' : 'bg-warning text-dark')
                    = match.played ? 'FINALIZADO' : 'PENDENTE'
              
                //- Confronto (Ajustado para col-md-8 para dar mais espaço ao centro)
                .col-md-8
                  .row.align-items-center.text-center(id=`match-row-${match._id}`)
                    //- Jogador 1 (col-12 no mobile, col-md-3 no desktop)
                    .col-12.col-md-3.mb-2.mb-md-0
                      span.fw-bold.text-uppercase.small= match.player1
                    
                    //- Container do Placar (Damos mais espaço aqui: col-6)
                    .col-12.col-md-6.my-2.my-md-0(id=`score-container-${match._id}`)
                      if match.played
                        .d-flex.justify-content-center.gap-1
                          span.badge.bg-dark= `${match.set1.p1}-${match.set1.p2}`
                          span.badge.bg-dark= `${match.set2.p1}-${match.set2.p2}`
                          if match.set3 && (match.set3.p1 > 0 || match.set3.p2 > 0)
                            span.badge.bg-danger= `TB:${match.set3.p1}-${match.set3.p2}`
                      else
                        span.text-muted vs
                    
                    .col-12.col-md-3.mt-2.mt-md-0
                      span.fw-bold.text-uppercase.small= match.player2
                
                //- Ação
                .col-md-2.text-end(id=`action-container-${match._id}`)
                  //- (Botão de edit/score que já tínhamos)
                  - var userEmail = user ? user.email : null
                  - var canEdit = user && (user.role === 'admin' || userEmail === match.player1Email || userEmail === match.player2Email)
  
    
                  if canEdit
                    button.btn.btn-sm.w-100(
                      class=match.played ? 'btn-outline-secondary' : 'btn-success'
                      onclick=`enableInlineEdit('${match._id}', ${JSON.stringify(match)})`
                    )
                      i.bi.bi-pencil-square.me-1
                      span= match.played ? 'Alterar' : 'Salvar'
                  else
                    span.badge.bg-light.text-muted Somente Visualização

      else
        .text-center.py-5
          p.text-muted No matches for this selection.

  //- SCRIPT PARA EDIÇÃO IN-LINE
  script.
    const originalRows = {};

    function enableInlineEdit(id, match) {
      const scoreContainer = document.getElementById(`score-container-${id}`);
      const actionContainer = document.getElementById(`action-container-${id}`);
      const statusBadge = document.getElementById(`status-${id}`);
      const row = document.getElementById(`match-row-${id}`);
         // Salva o estado atual ANTES de transformar em inputs
      originalRows[id] = {
        scoreHTML: scoreContainer.innerHTML,
        actionHTML: actionContainer.innerHTML,
        statusHTML: statusBadge ? statusBadge.outerHTML : '',
        rowClass: row.className
      };
         // Ajusta a linha para empilhar no celular e alinhar no desktop
      row.classList.add('flex-column', 'flex-md-row', 'gap-3', 'gap-md-0');
         scoreContainer.innerHTML = `
        <div class="row g-2 justify-content-center w-100">
          <div class="col-4 col-md-auto text-center">
            <small class="d-block text-muted" style="font-size:0.6rem">SET 1</small>
            <div class="d-flex gap-1 justify-content-center">
              <input type="number" id="s1p1-${id}" class="form-control form-control-sm text-center" style="width:45px" value="${match.set1?.p1 ?? ''}">
              <input type="number" id="s1p2-${id}" class="form-control form-control-sm text-center" style="width:45px" value="${match.set1?.p2 ?? ''}">
            </div>
          </div>
          <div class="col-4 col-md-auto text-center">
            <small class="d-block text-muted" style="font-size:0.6rem">SET 2</small>
            <div class="d-flex gap-1 justify-content-center">
              <input type="number" id="s2p1-${id}" class="form-control form-control-sm text-center" style="width:45px" value="${match.set2?.p1 ?? ''}">
              <input type="number" id="s2p2-${id}" class="form-control form-control-sm text-center" style="width:45px" value="${match.set2?.p2 ?? ''}">
            </div>
          </div>
          <div class="col-4 col-md-auto text-center bg-warning bg-opacity-10 rounded px-1">
            <small class="d-block text-danger fw-bold" style="font-size:0.55rem">TIE-BREAKÃO</small>
            <div class="d-flex gap-1 justify-content-center">
              <input type="number" id="s3p1-${id}" class="form-control form-control-sm text-center border-danger" style="width:45px" value="${match.set3?.p1 ?? ''}">
              <input type="number" id="s3p2-${id}" class="form-control form-control-sm text-center border-danger" style="width:45px" value="${match.set3?.p2 ?? ''}">
            </div>
          </div>
        </div>`;
         actionContainer.innerHTML = `
        <div class="d-flex flex-row flex-md-column gap-2 w-100">
          <button class="btn btn-sm btn-success flex-grow-1" onclick="saveInline('${id}')">
            <i class="bi bi-check-circle-fill"></i> SALVAR
          </button>
          <button class="btn btn-sm btn-outline-danger flex-grow-1" onclick="cancelInline('${id}')">
            <i class="bi bi-x-circle-fill"></i> VOLTAR
          </button>
        </div>`;
    }
       function cancelInline(id) {
      const data = originalRows[id];
      const row = document.getElementById(`match-row-${id}`);
      
      // Restaura HTML e Classes originais
      document.getElementById(`score-container-${id}`).innerHTML = data.scoreHTML;
      document.getElementById(`action-container-${id}`).innerHTML = data.actionHTML;
      row.className = data.rowClass;
      
      const statusElement = document.getElementById(`status-${id}`);
      if (statusElement) statusElement.outerHTML = data.statusHTML;
    }
       async function saveInline(id) {
      const scoreData = {
        s1p1: document.getElementById(`s1p1-${id}`).value,
        s1p2: document.getElementById(`s1p2-${id}`).value,
        s2p1: document.getElementById(`s2p1-${id}`).value,
        s2p2: document.getElementById(`s2p2-${id}`).value,
        s3p1: document.getElementById(`s3p1-${id}`).value || 0,
        s3p2: document.getElementById(`s3p2-${id}`).value || 0,
      };
         try {
        const response = await fetch(`/matches/update/${id}`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(scoreData)
        });
           if (response.ok) {
          // Reconstrói a linha visualmente sem refresh
          const row = document.getElementById(`match-row-${id}`);
          row.className = originalRows[id].rowClass; // Volta a classe original (lado a lado)
          
          let tbHtml = (scoreData.s3p1 > 0 || scoreData.s3p2 > 0) ? `<span class="badge bg-danger">TB:${scoreData.s3p1}-${scoreData.s3p2}</span>` : '';
          
          document.getElementById(`score-container-${id}`).innerHTML = `
            <div class="d-flex justify-content-center gap-1">
              <span class="badge bg-dark">${scoreData.s1p1}-${scoreData.s1p2}</span>
              <span class="badge bg-dark">${scoreData.s2p1}-${scoreData.s2p2}</span>
              ${tbHtml}
            </div>`;
             const statusBadge = document.getElementById(`status-${id}`);
          if (statusBadge) {
            statusBadge.className = 'badge rounded-pill bg-secondary';
            statusBadge.innerText = 'COMPLETED';
          }
             document.getElementById(`action-container-${id}`).innerHTML = `
            <button class="btn btn-sm btn-outline-secondary w-100" onclick='enableInlineEdit("${id}", ${JSON.stringify({...scoreData, played:true})})'>
              <i class="bi bi-pencil-square me-1"></i> Edit
            </button>`;
        }
      } catch (err) {
        alert("Erro ao salvar.");
      }
    }

    async function filterMatches(newClass, newGroup) {
      const container = document.getElementById('main-container');
      const tId = container.getAttribute('data-tournament');
      const activeClass = newClass || container.getAttribute('data-class');
      const activeGroup = newGroup || container.getAttribute('data-group');
  
      try {
        const response = await fetch(`/matches/filter?tournamentId=${tId}&class=${activeClass}&group=${activeGroup}`);
        const data = await response.json();
  
        if (data.matches) {
          // CORREÇÃO AQUI: O nome deve bater com a definição abaixo
          updateFilterUI(activeClass, activeGroup);
          
          renderMatchesList(data.matches, data.user);
          
          container.setAttribute('data-class', activeClass);
          container.setAttribute('data-group', activeGroup);
          
          const newUrl = `/matches/pending?tournamentId=${tId}&class=${activeClass}&group=${activeGroup}`;
          window.history.pushState({ path: newUrl }, '', newUrl);
        }
      } catch (err) {
        console.error("Erro ao filtrar:", err);
      }
    }
  
    // DEFINIÇÃO DA FUNÇÃO (Certifique-se de que o nome é este)
    function updateFilterUI(cls, grp) {
      document.querySelectorAll('.filter-btn-class').forEach(btn => {
        if (btn.getAttribute('data-class') === cls) {
          btn.classList.replace('btn-outline-success', 'btn-success');
          btn.classList.add('fw-bold');
        } else {
          btn.classList.replace('btn-success', 'btn-outline-success');
          btn.classList.remove('fw-bold');
        }
      });
  
      document.querySelectorAll('.filter-btn-group').forEach(btn => {
        if (btn.getAttribute('data-group') == grp) {
          btn.classList.replace('btn-outline-dark', 'btn-dark');
          btn.classList.add('fw-bold');
        } else {
          btn.classList.replace('btn-dark', 'btn-outline-dark');
          btn.classList.remove('fw-bold');
        }
      });
    }

    function renderMatchesList(matches, user) {
        const listContainer = document.querySelector('#matches-list-container');
        console.log("Limpando container:", listContainer); // Veja se ele aponta para o lugar certo
        
        // Use textContent para garantir que o navegador limpe até nós de texto órfãos
        while (listContainer.firstChild) {
            listContainer.removeChild(listContainer.firstChild);
        }
    
        if (!matches || matches.length === 0) {
            listContainer.innerHTML = '<p class="text-center py-5">Sem jogos.</p>';
            return;
        }
    
        let currentRound = 0;
        matches.forEach((match, index) => {
            // Cabeçalho da Semana
            if (match.round !== currentRound) {
                currentRound = match.round;
                const roundHeader = `
                    <div class="mt-5 mb-3" data-aos="fade-right">
                        <h4 class="text-uppercase fw-900" style="color: var(--clay-orange); border-left: 4px solid var(--clay-orange); padding-left: 15px;">
                            Semana ${currentRound} 
                            <small class="text-muted fs-6 ms-2">— Data limite: ${new Date(match.deadline).toLocaleDateString('pt-BR')}</small>
                        </h4>
                    </div>`;
                listContainer.insertAdjacentHTML('beforeend', roundHeader);
            }
    
            // Lógica de Permissão de Edição
            const userEmail = user ? user.email : null;
            const canEdit = user && (user.role === 'admin' || userEmail === match.player1Email || userEmail === match.player2Email);
            const delay = (index % 5) * 50;
            const scoreHtml = match.played
            ? `<div class="d-flex justify-content-center gap-1">
                 <span class="badge bg-dark">${match.set1.p1}-${match.set1.p2}</span>
                 <span class="badge bg-dark">${match.set2.p1}-${match.set2.p2}</span>
                 ${match.set3 && (match.set3.p1 > 0 || match.set3.p2 > 0)
                   ? `<span class="badge bg-danger">TB:${match.set3.p1}-${match.set3.p2}</span>`
                   : ''}
               </div>`
            : `<span class="text-muted">vs</span>`;
            const matchHTML = `
                <div class="card mb-2 border-0 shadow-sm" ${match.played ? 'bg-light' : ''}" data-aos="fade-up" data-aos-delay="${delay}">
                  <!-- A classe 'bg-light' deve ser adicionada dinamicamente se o jogo estiver finalizado -->
                  <div class="card-body py-3" id="match-row-${match._id}">

                    <div class="row align-items-center">

                      <!-- Status -->
                      <div class="col-md-2 text-center border-end">
                        <!-- Classe muda entre 'bg-secondary' (finalizado) e 'bg-warning text-dark' (pendente) -->
                        <span class="badge rounded-pill ${match.played ? 'bg-secondary' : 'bg-warning text-dark'}" id="status-${match._id}">
                          ${match.played ? 'FINALIZADO' : 'PENDENTE'}
                        </span>
                      </div>

                      <!-- Confronto -->
                      <div class="col-md-8">
                        <div class="row align-items-center text-center" id="match-row-${match._id}">

                          <!-- Jogador 1 -->
                          <div class="col-12.col-md-3 mb-2 mb-md-0">
                            <span class="fw-bold text-uppercase small">${match.player1}</span>
                          </div>

                          <!-- Container do Placar -->
                          <div class="col-12 col-md-6 my-2 my-md-0" id="score-container-${match._id}">
                            <!-- Se jogado, exibe os badges; se não, exibe o 'vs' -->
                            ${scoreHtml}
                          </div>

                          <!-- Jogador 2 -->
                          <div class="col-12 col-md-3 mt-2 mt-md-0">
                            <span class="fw-bold text-uppercase small">${match.player2}</span>
                          </div>
                        </div>
                      </div>

                      <!-- Ação -->
                      <div class="col-md-2 text-end" id="action-container-${match._id}">
                         ${canEdit ? `
                             <button class="btn btn-sm w-100 ${match.played ? 'btn-outline-secondary' : 'btn-success'}"
                                     onclick='enableInlineEdit("${match._id}", ${JSON.stringify(match)})'>
                                 <i class="bi bi-pencil-square me-1"></i>
                                 ${match.played ? 'Alterar' : 'Salvar'}
                             </button>
                         ` : '<span class="badge bg-light text-muted">Somente visualização</span>'}
                      </div>
                    </div>
                  </div>
                </div>
            `;
            // Construção do Card da Partida
            const matchHTML2 = `
                <div class="card mb-2 border-0 shadow-sm ${match.played ? 'bg-light' : ''}" data-aos="fade-up" id="match-card-${match._id}">
                    <div class="card-body py-3" id="match-row-${match._id}">
                        <div class="row align-items-center">
                            <!-- Status -->
                            <div class="col-md-2 text-center border-end">
                                <span class="badge rounded-pill ${match.played ? 'bg-secondary' : 'bg-warning text-dark'}">
                                    ${match.played ? 'FINALIZADO' : 'PENDENTE'}
                                </span>
                            </div>
    
                            <!-- Confronto -->
                            <div class="col-md-8">
                                <div class="row align-items-center text-center">
                                    <div class="col-4 text-end">
                                        <span class="fw-bold me-2">${match.player1}</span>
                                    </div>
    
                                    <div class="col-4" id="score-container-${match._id}">
                                        ${match.played ? renderScoreBadges(match) : '<span class="text-muted small">VS</span>'}
                                    </div>
    
                                    <div class="col-4 text-start">
                                        <span class="fw-bold ms-2">${match.player2}</span>
                                    </div>
                                </div>
                            </div>
    
                            <!-- Ação -->
                            <div class="col-md-2 text-end" id="action-container-${match._id}">
                                ${canEdit ? `
                                    <button class="btn btn-sm w-100 ${match.played ? 'btn-outline-secondary' : 'btn-success'}" 
                                            onclick='enableInlineEdit("${match._id}", ${JSON.stringify(match)})'>
                                        <i class="bi bi-pencil-square me-1"></i>
                                        ${match.played ? 'Edit' : 'Score'}
                                    </button>
                                ` : '<span class="badge bg-light text-muted">Somente visualização</span>'}
                            </div>
                        </div>
                    </div>
                </div>`;
            
            listContainer.insertAdjacentHTML('beforeend', matchHTML);
        });
    
        // REINICIALIZA O AOS para animar os novos itens
        if (typeof AOS !== 'undefined') AOS.refresh();
    }
    
    // Função auxiliar para gerar os placares dentro da lista JS
    function renderScoreBadges(match) {
        let tbHtml = (match.set3 && (match.set3.p1 > 0 || match.set3.p2 > 0)) 
            ? `<span class="badge bg-danger">TB:${match.set3.p1}-${match.set3.p2}</span>` 
            : '';
        
        return `
            <div class="d-flex justify-content-center gap-1">
                <span class="badge bg-dark">${match.set1.p1}-${match.set1.p2}</span>
                <span class="badge bg-dark">${match.set2.p1}-${match.set2.p2}</span>
                ${tbHtml}
            </div>`;
    }
//- extends layout

