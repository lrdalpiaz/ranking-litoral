doctype html
html(lang="pt-br")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title RANKING TOP LITORAL NORTE - RS
    //- CONFIGURAÇÃO DO FAVICON
    link(rel="icon" type="image/png" href="/images/favicon-32x32.png")
    //- Se quiser suporte para dispositivos Apple (ícone na tela inicial)
    link(rel="apple-touch-icon" href="/images/favicon-32x32.png")
    //- Bootstrap 5 & Icons
    link(rel="stylesheet" href="/stylesheets/bootstrap.min.css")
    //- link(rel="stylesheet" href="https://jsdelivr.net")    
    //- 2. AOS Animation CSS
    link(href="/stylesheets/aos.css" rel="stylesheet")
    //- Fontes: Playfair Display para títulos (clássico) e Lato para corpo
    link(href="https://googleapis.com" rel="stylesheet")
    link(href="https://cdn.jsdelivr.net/npm/tom-select@2.5.2/dist/css/tom-select.css" rel="stylesheet")
    
    style.
      :root {
        --clay-orange: #d35400; /* Laranja Saibro */
        --clay-dark: #a04000;   /* Saibro Escuro */
        --forest-green: #1b4d3e; /* Verde Roland Garros */
        --cream-bg: #fdfaf5;    /* Creme Clássico */
      }
      
      body {
        font-family: 'Lato', sans-serif;
        background-color: #fdfaf5; 
        background-attachment: fixed;
        /* Centraliza o logo e impede que ele se repita */
        background-position: center;
        background-repeat: no-repeat;
        background-size: 60%; /* Ajuste a porcentagem para aumentar/diminuir o logo no fundo */
        color: #1b4d3e;
        min-height: 100vh;
      }

      h1, h2, h3, .navbar-brand {
        font-family: 'Playfair Display', serif;
        font-weight: 900;
      }

      /* Navbar Elegante */
      .navbar {
        background-color: var(--forest-green) !important;
        border-bottom: 4px solid var(--clay-orange);
        padding: 0.8rem 0;
      }
      .navbar-brand { color: white !important; letter-spacing: 1px; }
      .nav-link { color: rgba(255,255,255,0.9) !important; font-weight: 700; margin: 0 10px; text-transform: uppercase; font-size: 0.85rem; }
      .nav-link:hover { color: var(--clay-orange) !important; }

      /* Cards Estilo Clube */
      .card {
        background: white !important;
        border: none;
        border-radius: 4px; /* Menos arredondado, mais clássico */
        box-shadow: 0 4px 15px rgba(0,0,0,0.05);
        border-top: 5px solid var(--clay-orange);
      }
      .card-header {
        background: white !important;
        border-bottom: 1px solid #eee;
        color: var(--forest-green);
        padding: 1.2rem;
      }

      /* Botões e Badges */
      .btn-success {
        background-color: var(--clay-orange);
        border: none;
        border-radius: 2px;
        padding: 10px 25px;
        text-transform: uppercase;
        font-weight: 700;
        transition: 0.3s;
      }
      .btn-success:hover {
        background-color: var(--clay-dark);
        transform: translateY(-1px);
      }

      .table thead {
        background-color: var(--forest-green);
        color: white;
      }
      .table-hover tbody tr:hover {
        background-color: rgba(211, 84, 0, 0.05);
      }

      /* Badge de destaque */
      .badge.bg-dark { background-color: var(--forest-green) !important; }
      
  body
    nav.navbar.navbar-expand-lg.navbar-dark.sticky-top.mb-4.shadow
      .container
        a.navbar-brand.d-flex.align-items-center(href="/matches/ranking") 
          img.me-2(src="/images/logo-nav.png" alt="Logo" style="height: 40px; width: auto;")
          span.d-none.d-sm-inline RANKING TOP LITORAL NORTE - RS
        
        button.navbar-toggler(type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav")
          span.navbar-toggler-icon
        
        #navbarNav.collapse.navbar-collapse
          ul.navbar-nav.ms-auto
            li.nav-item
              a.nav-link(href="/matches/ranking") 
                i.bi.bi-trophy.me-1
                | Classificação
            li.nav-item
              a.nav-link(href="/matches/pending") 
                i.bi.bi-calendar3.me-1
                | Agenda
            if user
              if user.role === 'admin'
                li.nav-item
                  a.btn.btn-success.btn-sm(href="/tournaments/new") + Nova Temporada
              li.nav-item
                span.nav-link.text-white Olá, #{user.name}
                a.nav-link(href="/logout") Logout
              li.nav-item
            else
              li.nav-item
                a.nav-link(href="/login") Login

    main.pb-5
      block content

    footer.container.text-center.py-5.text-muted.small
      p.mb-1 Litoral Tennis Tour — Rio Grande do Sul
      p.text-uppercase(style="letter-spacing: 2px;") Grand Slam Tradition

    script(src="/javascripts/aos.js")
    script.
      AOS.init({ duration: 800, once: true }); // Inicializa animações
    
    script(src="/javascripts/bootstrap.bundle.min.js")
    script(src="https://cdn.jsdelivr.net/npm/tom-select@2.5.2/dist/js/tom-select.complete.min.js")
